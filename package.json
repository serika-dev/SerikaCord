{
  "name": "serikacord",
  "version": "1.1.1",
  "private": true,
  "packageManager": "bun@1.3.2",
  "scripts": {
    "dev": "NODE_ENV=development UV_THREADPOOL_SIZE=16 bun server.ts",
    "dev:next": "next dev --webpack",
    "build": "next build --webpack",
    "start": "NODE_ENV=production UV_THREADPOOL_SIZE=16 bun server.ts",
    "start:next": "next start",
    "gateway": "bun scripts/gateway.ts",
    "lint": "eslint",
    "desktop": "cd desktop && bun run start",
    "desktop:dev": "cd desktop && bun run dev",
    "desktop:build": "cd desktop && bun run build",
    "mobile:ios": "cd mobile && bun run ios",
    "mobile:android": "cd mobile && bun run android",
    "mobile:sync": "cd mobile && bun run cap:sync",
    "check:theme": "bash scripts/check-theme-hardcoded.sh",
    "check:chat-media": "bash scripts/check-chat-media-hardcoded.sh",
    "translate:push": "node scripts/sync-translations.js push",
    "translate:pull": "node scripts/sync-translations.js pull",
    "translate:sync": "node scripts/sync-translations.js sync",
    "translate:status": "node scripts/sync-translations.js status",
    "translate:keys": "node scripts/sync-translations.js keys"
  },
