# SerikaCord Configuration
NODE_ENV=development
PORT=3000

# Database
MONGO_URI=mongodb://localhost:27017/serikacord
MONGO_DB_NAME=serikacord
MONGO_PASSWORD=your-mongo-password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Backblaze B2 Storage
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=serikacord-media
B2_BUCKET_ID=your-bucket-id
B2_ENDPOINT=s3.eu-central-003.backblazeb2.com

# CDN URL (defaults to B2 public URL)
CDN_URL=https://serikacord-media.s3.eu-central-003.backblazeb2.com

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://serikacord.com,https://serika.dev

# Email (AWS SES)
AWS_EMAIL_ENDPOINT=email-smtp.us-east-1.amazonaws.com
AWS_EMAIL_SMTP_PORT=587
AWS_EMAIL_SMTP_USERNAME=your-smtp-username
AWS_EMAIL_PASS=your-smtp-password
EMAIL_FROM=SerikaCord <noreply@serika.email>

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Last.fm — API key + shared secret (register at https://www.last.fm/api/account/create)
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_API_SECRET=your-lastfm-shared-secret

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Twitch OAuth (https://dev.twitch.tv/console)
# Also used to authenticate the IGDB game-metadata proxy (/api/igdb/game),
# which powers desktop rich-presence game detection.
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Steam Web API key (https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=your-steam-api-key

# Public frontend URL (used for OAuth redirect callbacks)
FRONTEND_URL=https://serikacord.com

# Stripe (for premium)
STRIPE_SECRET_KEY=sk_test_your-stripe-key

# Serika GIFs API
SERIKA_GIFS_API=https://gifs.serika.dev/api
SERIKA_GIFS_API_KEY=your-serika-gifs-api-key
# Legacy alias still supported by app code:
# SERIKA_GIFS=your-serika-gifs-api-key

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# File Upload Limits (in bytes)
MAX_FILE_SIZE=524288000
MAX_FILE_SIZE_PREMIUM=2147483648
MAX_AVATAR_SIZE=5242880
MAX_BANNER_SIZE=10485760
MAX_MESSAGE_LENGTH=4000

# SerikaMoe (streaming) — live "now watching" presence
SERIKA_MOE_URL=https://serika.moe
SERIKA_MOE_SERVICE_KEY=your-serika-moe-service-key
# Legacy alias also accepted:
# SERIKA_SERVICE_KEY=your-serika-moe-service-key

# Discord Bot (optional — for Discord bridge real-time sync)
# When enabled, the bot connects to Discord Gateway and forwards messages bidirectionally.
# Set DISABLE_DISCORD_BOT=1 on canary/dev instances to prevent dual bot connections.
SERIKA_DISCORD_TOKEN=your-discord-bot-token
SERIKA_DISCORD_ID=your-discord-bot-user-id
# DISABLE_DISCORD_BOT=1

# Fish Audio TTS (optional — high-quality AI voices for /tts [fish:ID])
# Get your API key at https://fish.audio
# Voice presets are configured in the admin panel (TTS Management tab), not env vars.
FISH_API_KEY=your-fish-audio-api-key

# General Translation (i18n — https://generaltranslation.com)
# Get your keys at https://dash.generaltranslation.com or run `npx gt auth`
# Dev keys start with gtx-dev-, production keys start with gtx-api-
GT_PROJECT_ID=your-gt-project-id
GT_API_KEY=your-gt-api-key
