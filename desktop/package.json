{
  "name": "serikacord-desktop",
  "version": "0.0.3",
  "description": "SerikaCord Desktop App",
  "main": "main.js",
  "author": "SerikaCord Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/serika-dev/SerikaCord.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder -mwl --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "dev.serika.serikacord",
    "productName": "SerikaCord",
    "copyright": "Copyright © 2026 SerikaCord",
    "publish": {
      "provider": "github",
      "owner": "serika-dev",
      "repo": "SerikaCord",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "icon": "resources/icons",
      "category": "Network;Chat;InstantMessaging",
      "desktop": {
        "Name": "SerikaCord",
        "Comment": "Chat with friends and communities",
        "Keywords": "chat;discord;messaging;voice;video",
        "StartupWMClass": "serikacord"
      },
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "tar.gz",
          "arch": ["x64"]
        }
      ],
      "maintainer": "SerikaCord Team"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
